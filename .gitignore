# ═══════════════════════════════════════════
#  OmniShell .gitignore
#  RULE: If it contains secrets → it stays local
# ═══════════════════════════════════════════

# ── CRITICAL: Credentials & Secrets ─────────────────────────────────────────
# Raw config with SSH passwords + GitHub token — NEVER ship this
sachin-person.config
*.config

# Encrypted slim config — still contains usernames, keep local
sachin-person.cfg
*.cfg

# All .env files
.env
.env.*
.env.local
.env.*.local

# Any file that looks like a secret
*secret*
*password*
*credentials*
*token*

# ── CRITICAL: Code Signing Certificates ────────────────────────────────────
# Private keys and certificates — leak = app can be forged
build/*.pfx
build/*.p12
build/*.key
build/*.pem
*.pfx
*.p12
*.pem
*.key
*.crt
*.cer

# App Store Connect API keys (notarization) — same severity as the above
*.p8
AuthKey_*.p8
setup_mac_notarization.js

# ── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
jspm_packages/
web_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyc
.Python

# ── Electron Build Outputs ──────────────────────────────────────────────────
# Large binary artifacts — distribute via GitHub Releases, not source tree
dist/
release/
out/

# ── Generated / Derived Files ────────────────────────────────────────────────
# Auto-generated codebase dump (large, regenerated by aggregate_codebase.js)
omnishell_codebase.md

# Network scan outputs — may reveal internal network topology
network_scan_report.json
network_scan_report.csv

# ── OS Metadata ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── Editor & IDE ─────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/*.code-snippets
.idea/
*.swp
*.swo
*~

# ── Temporary / Debug ────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
crash.log
