{
    "name":  "omnishell",
    "version":  "1.5.0",
    "description":  "Cross-platform network device scanner and remote SSH controller.",
    "main":  "main.js",
    "scripts":  {
                    "start":  "electron .",
                    "dist":  "electron-builder"
                },
    "build":  {
                  "appId":  "com.antigravity.omnishell",
                  "productName":  "OmniShell",
                  "icon":  "assets/icon.png",
                  "directories":  {
                                      "output":  "dist"
                                  },
                  "files":  [
                                "main.js",
                                "preload.js",
                                "index.html",
                                "index.css",
                                "renderer.js",
                                "node_modules/**/*"
                            ],
                  "win":  {
                              "icon":  "assets/icon.png",
                              "target":  [
                                             "nsis",
                                             "zip"
                                         ]
                          },
                  "nsis":  {
                               "oneClick":  false,
                               "allowToChangeInstallationDirectory":  true,
                               "createDesktopShortcut":  true,
                               "createStartMenuShortcut":  true,
                               "shortcutName":  "OmniShell",
                               "uninstallDisplayName":  "Uninstall OmniShell",
                               "runAfterFinish":  true
                           },
                  "mac":  {
                              "target":  [
                                             "dmg",
                                             "zip"
                                         ],
                              "category":  "public.app-category.utilities"
                          },
                  "linux":  {
                                "target":  [
                                               "AppImage",
                                               "deb"
                                           ],
                                "category":  "Utility"
                            }
              },
    "keywords":  [

                 ],
    "author":  "",
    "license":  "ISC",
    "dependencies":  {
                         "ssh2":  "^1.16.0",
                         "xterm":  "^5.3.0",
                         "xterm-addon-fit":  "^0.8.0"
                     },
    "devDependencies":  {
                            "electron":  "^31.7.7",
                            "electron-builder":  "^26.15.3"
                        }
}
