{
    "name": "omnishell",
    "version": "2.15.0",
    "description": "Cross-platform network device scanner and remote SSH controller.",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dist": "electron-builder",
        "build-all": "node build_dist.js",
        "release": "node remote_build_release.js"
    },
    "build": {
        "appId": "com.antigravity.omnishell",
        "productName": "OmniShell",
        "icon": "assets/icon.png",
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "preload.js",
            "index.html",
            "index.css",
            "renderer.js",
            "node_modules/**/*"
        ],
        "win": {
            "icon": "assets/icon.png",
            "target": [
                "nsis",
                "zip"
            ]
        },
        "nsis": {
            "oneClick": true,
            "allowToChangeInstallationDirectory": false,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "OmniShell",
            "uninstallDisplayName": "Uninstall OmniShell",
            "runAfterFinish": true
        },
        "mac": {
            "target": [
                "dmg",
                "zip",
                "pkg"
            ],
            "category": "public.app-category.utilities",
            "hardenedRuntime": true,
            "gatekeeperAssess": false,
            "entitlements": "build/entitlements.mac.plist",
            "entitlementsInherit": "build/entitlements.mac.plist"
        },
        "linux": {
            "target": [
                "AppImage",
                "zip",
                "deb"
            ],
            "category": "Utility",
            "maintainer": "Sachin Kumar <sachin@omnishell.app>"
        }
    },
    "homepage": "https://github.com/sachin6174/all-Devices-controller",
    "keywords": [],
    "author": "Sachin Kumar <sachin@omnishell.app>",
    "license": "ISC",
    "dependencies": {
        "ssh2": "^1.16.0",
        "xterm": "^5.3.0",
        "xterm-addon-fit": "^0.8.0"
    },
    "devDependencies": {
        "electron": "^31.7.7",
        "electron-builder": "24.13.3"
    }
}